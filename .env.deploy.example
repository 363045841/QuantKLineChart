# KLineChart 部署配置
# 复制此文件为 .env.deploy 并修改配置

# ============================================
# 端口配置
# ============================================

# 前端端口
PORT=3000

# Baostock 后端端口
BAOSTOCK_PORT=8000

# ============================================
# 外部服务（可选）
# ============================================

# AKTools 地址（如果在其他服务器或宿主机运行）
# AKTOOLS_URL=http://host.docker.internal:8080/

# ============================================
# Docker 配置
# ============================================
COMPOSE_PROJECT_NAME=klinechart-demo
